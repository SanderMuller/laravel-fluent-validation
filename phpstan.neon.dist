includes:
    - phpstan-baseline.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-dangerous-calls.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-execution-calls.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-insecure-calls.neon

parameters:
    tmpDir: .cache/phpstan

    paths:
        - src
        - tests

    level: max

    type_coverage:
        return: 100
        param: 100
        property: 100
        constant: 0
        declare: 100

    type_perfect:
        null_over_false: true
        no_mixed: false
        narrow_param: false
        narrow_return: true

    cognitive_complexity:
        class: 80
        function: 20

    strictRules:
        allRules: true

    editorUrl: 'phpstorm://open?file=%%file%%&line=%%line%%'

    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        -
            identifier: trait.unused
            reportUnmatched: false
        - identifier: ternary.condNotBoolean

        # Pest $this->fail() in closures — PHPStan can't resolve $this to TestCase
        -
            identifier: method.notFound
            path: tests/
            reportUnmatched: false

        # Pest framework internals — expect() chains use Pest's internal Expectation class
        -
            identifier: method.internalClass
            path: tests/
            reportUnmatched: false
        # PHPUnit's AssertionFailedError / ExpectationFailedException are marked @internal
        # but legitimately referenced from tests when asserting on assertion failures
        -
            identifier: classConstant.internalClass
            path: tests/
            reportUnmatched: false
        # Pest higher-order expectations and test helpers return mixed
        -
            identifier: method.nonObject
            path: tests/
            reportUnmatched: false
        -
            identifier: staticMethod.dynamicCall
            path: tests/
            reportUnmatched: false
        -
            identifier: offsetAccess.nonOffsetAccessible
            path: tests/
            reportUnmatched: false
        -
            identifier: property.nonObject
            path: tests/
            reportUnmatched: false
        -
            identifier: property.notFound
            path: tests/
            reportUnmatched: false
        # Pest arch test API (->expect()->each->not->...)
        -
            identifier: method.notFound
            path: tests/ArchTest.php
            reportUnmatched: false
        # Pest Arch's ArchExpectation interface is marked @internal but its
        # fluent API (->ignoring(), ->toOnlyUse(), etc.) is precisely how the
        # public Arch API is meant to be used.
        -
            identifier: method.internalInterface
            path: tests/ArchTest.php
            reportUnmatched: false
